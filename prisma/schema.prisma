generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Medicamento {
  id                String   @id @default(cuid())
  nombre            String
  principioActivo   String
  familia           String
  presentacion      String
  laboratorio       String
  precioReferencia  Float?
  farmacia          String?
  efectosAdversos   String[]
  contraindicaciones String[]
  indicaciones      String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  isPro     Boolean  @default(false)
  stripeId  String?
  createdAt DateTime @default(now())
}