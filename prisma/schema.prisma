generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Medicamento {
  id                 String              @id @default(cuid())
  nombre             String              @unique
  principioActivo    String
  familia            String
  presentacion       String
  laboratorio        String
  precioReferencia   Float?
  vidaMedia          String?
  nivelInteracciones String?
  efectosAdversos    String[]
  contraindicaciones String[]
  indicaciones       String[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  favoritos          Favorito[]
}

model Usuario {
  id                       String              @id @default(cuid())
  email                    String              @unique
  password                 String?
  nombre                   String?
  isPro                    Boolean             @default(false)
  proPlan                  String?
  proSubscriptionId        String?
  proSubscriptionStatus    String?
  proExpiresAt             DateTime?
  stripeId                 String?
  passwordResetTokenHash   String?
  passwordResetExpiresAt   DateTime?
  createdAt                DateTime            @default(now())
  favoritos                Favorito[]
  historial                HistorialBusqueda[]
  feedbacks                Feedback[]

  @@index([passwordResetTokenHash])
}

model Favorito {
  id            String      @id @default(cuid())
  usuarioId     String
  medicamentoId String
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  medicamento   Medicamento @relation(fields: [medicamentoId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([usuarioId, medicamentoId])
}

model HistorialBusqueda {
  id        String   @id @default(cuid())
  usuarioId String
  query     String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  type      String
  rating    Int
  title     String?
  message   String
  source    String   @default("web")
  createdAt DateTime @default(now())
  usuario   Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model SidebarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime?
  url         String?
  source      String?
  type        String    @default("conference")
  createdAt   DateTime  @default(now())

  @@index([date])
}

model ComparisonInsightCache {
  id              String   @id @default(cuid())
  requestHash     String   @unique
  medicationIds   Json
  patientProfile  Json
  response        Json
  sourceModel     String
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
}

model SidebarChatCache {
  id               String   @id @default(cuid())
  requestHash      String   @unique
  message          String
  normalizedMessage String
  response         String
  medicationIds    Json
  isPro            Boolean  @default(false)
  sourceModel      String
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([normalizedMessage])
}
